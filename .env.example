# HTTP
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_SHUTDOWN_TIMEOUT=15s

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=orgstructure
DB_PASSWORD=orgstructure
DB_NAME=orgstructure
DB_SSLMODE=disable

# Migrations
MIGRATIONS_DIR=./migrations
RUN_MIGRATIONS_ON_START=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
